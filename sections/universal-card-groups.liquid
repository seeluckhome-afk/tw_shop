{% liquid
  assign desktop_columns = section.settings.desktop_columns
  assign mobile_columns = section.settings.mobile_columns
%}

<section id="shopify-section-{{ section.id }}" class="ucg">
  <div class="ucg__container">
    {% if section.settings.heading != blank %}
      <h2 class="ucg__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="ucg__grid" role="list">
      {% for block in section.blocks %}
        <article class="ucg__card" role="listitem" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="ucg__media">
              {{
                block.settings.image
                | image_url: width: 1200
                | image_tag:
                  class: 'ucg__image',
                  loading: 'lazy',
                  widths: '240, 360, 480, 720, 960, 1200',
                  sizes: '(max-width: 767px) calc((100vw - 32px) / ' | append: mobile_columns | append: '), calc((100vw - 32px) / ' | append: desktop_columns | append: ')',
                  alt: block.settings.title
              }}
            </div>
          {% endif %}

          <div class="ucg__content">
            {% if block.settings.title != blank %}
              <h3 class="ucg__card-title">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.description != blank %}
              <div class="ucg__description rte">{{ block.settings.description }}</div>
            {% endif %}

            {% if block.settings.show_button and block.settings.button_link != blank %}
              <a class="ucg__button" href="{{ block.settings.button_link }}">
                {{ block.settings.button_label | default: 'Learn more' }}
              </a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

{% style %}
  #shopify-section-{{ section.id }} {
    --ucg-desktop-columns: {{ section.settings.desktop_columns }};
    --ucg-mobile-columns: {{ section.settings.mobile_columns }};
    --ucg-gap: {{ section.settings.card_gap }}px;
    --ucg-radius: {{ section.settings.card_radius }}px;
    --ucg-border-width: {{ section.settings.card_border_width }}px;
    --ucg-image-height: {{ section.settings.image_height }}px;
    --ucg-vertical-padding: {{ section.settings.section_vertical_padding }}px;
    --ucg-horizontal-padding: {{ section.settings.section_horizontal_padding }}px;
    --ucg-bg: {{ section.settings.section_background }};
    --ucg-card-bg: {{ section.settings.card_background }};
    --ucg-card-border: {{ section.settings.card_border_color }};
    --ucg-text-color: {{ section.settings.text_color }};
    --ucg-button-bg: {{ section.settings.button_background }};
    --ucg-button-text: {{ section.settings.button_text_color }};
  }

  #shopify-section-{{ section.id }}.ucg {
    background: var(--ucg-bg);
  }

  #shopify-section-{{ section.id }} .ucg__container {
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
    padding: var(--ucg-vertical-padding) var(--ucg-horizontal-padding);
  }

  #shopify-section-{{ section.id }} .ucg__heading {
    margin: 0 0 24px;
    color: var(--ucg-text-color);
    text-transform: none;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .ucg__grid {
    display: grid;
    grid-template-columns: repeat(var(--ucg-desktop-columns), minmax(0, 1fr));
    gap: var(--ucg-gap);
  }

  #shopify-section-{{ section.id }} .ucg__card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    background: var(--ucg-card-bg);
    border: var(--ucg-border-width) solid var(--ucg-card-border);
    border-radius: var(--ucg-radius);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .ucg__media {
    height: var(--ucg-image-height);
    background: rgba(0, 0, 0, 0.03);
  }

  #shopify-section-{{ section.id }} .ucg__image {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    object-position: center;
    display: block;
  }

  #shopify-section-{{ section.id }} .ucg__content {
    color: var(--ucg-text-color);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }

  #shopify-section-{{ section.id }} .ucg__card-title {
    margin: 0;
    text-transform: none;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .ucg__description {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .ucg__description > *:first-child {
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .ucg__description > *:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .ucg__button {
    margin-top: auto;
    align-self: flex-start;
    display: inline-block;
    padding: 10px 16px;
    border-radius: 999px;
    background: var(--ucg-button-bg);
    color: var(--ucg-button-text);
    text-decoration: none;
    line-height: 1;
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .ucg__grid {
      grid-template-columns: repeat(var(--ucg-mobile-columns), minmax(0, 1fr));
    }

    #shopify-section-{{ section.id }} .ucg__content {
      padding: 16px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Universal card groups",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Appointment Service"
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "default": "1",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ]
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 900,
      "max": 1800,
      "step": 20,
      "default": 1400,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_horizontal_padding",
      "label": "Section left/right padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "section_vertical_padding",
      "label": "Section top/bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Card gap",
      "min": 8,
      "max": 48,
      "step": 2,
      "default": 20,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Card border width",
      "min": 0,
      "max": 8,
      "step": 1,
      "default": 0,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "Image height",
      "min": 120,
      "max": 420,
      "step": 10,
      "default": 200,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "default": "contain",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ]
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border color",
      "default": "#e2e2e2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2b2b2b"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#2b2b2b"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Design Consult Service"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<ul><li>Tailored Advice</li><li>Curated Fabrics</li><li>Custom Solutions</li></ul>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image / icon"
        },
        {
          "type": "checkbox",
          "id": "show_button",
          "label": "Show button",
          "default": true
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Book Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Universal card groups",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
