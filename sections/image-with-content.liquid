{% liquid
  assign section_id = 'universal-split-' | append: section.id
%}

<section id="{{ section_id }}" class="universal-split-section">
  <div class="universal-split page-width page-width--{{ section.settings.section_width }}">
    <div class="universal-split__rows">
      {% for block in section.blocks %}
        {% liquid
          assign left_type = block.settings.left_type
          assign right_type = block.settings.right_type

          assign has_left = false
          assign has_right = false

          if left_type != 'empty'
            assign has_left = true
          endif

          if right_type != 'empty'
            assign has_right = true
          endif

          if has_left == false and has_right == false
            continue
          endif

          assign row_layout = 'two'
          if has_left and has_right == false
            assign row_layout = 'single-left'
          elsif has_right and has_left == false
            assign row_layout = 'single-right'
          endif

          assign mobile_order = block.settings.mobile_order
        %}

        <article
          class="universal-split__row universal-split__row--{{ row_layout }} universal-split__row--mobile-{{ mobile_order }}"
          id="universal-split-row-{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          <div class="universal-split__grid">
            {% if has_left %}
              <div class="universal-split__cell universal-split__cell--left universal-split__cell--{{ left_type }}">
                {% if left_type == 'image' %}
                  {% assign left_ratio = block.settings.left_image_ratio %}
                  {% assign left_alt = block.settings.left_image_alt | default: block.settings.left_image.alt | escape %}
                  {% if block.settings.left_image_link != blank %}
                    <a class="universal-split__media-link" href="{{ block.settings.left_image_link }}">
                  {% endif %}
                  <div class="universal-split__media universal-split__media--{{ left_ratio }}">
                    {% if block.settings.left_image != blank %}
                      {{
                        block.settings.left_image
                        | image_url: width: 2400
                        | image_tag:
                          loading: 'lazy',
                          widths: '375, 550, 750, 900, 1100, 1400, 1700, 2000, 2400',
                          class: 'universal-split__image',
                          alt: left_alt
                      }}
                    {% else %}
                      <div class="universal-split__placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
                    {% endif %}
                  </div>
                  {% if block.settings.left_image_link != blank %}
                    </a>
                  {% endif %}
                {% elsif left_type == 'content' %}
                  <div class="universal-split__content" style="max-width: {{ block.settings.left_content_max_width }}px;">
                    {% if block.settings.left_heading != blank %}
                      <h2 class="universal-split__heading universal-split__heading--left-{{ block.id }}">{{ block.settings.left_heading }}</h2>
                    {% endif %}

                    {% if block.settings.left_text != blank %}
                      <div class="universal-split__text universal-split__text--left-{{ block.id }} rte">{{ block.settings.left_text }}</div>
                    {% endif %}

                    {% if block.settings.left_show_button and block.settings.left_button_label != blank %}
                      <div class="universal-split__button-wrap universal-split__button-wrap--{{ block.settings.left_button_alignment }}">
                        <a
                          href="{% if block.settings.left_button_link != blank %}{{ block.settings.left_button_link }}{% else %}#{% endif %}"
                          class="universal-split__button"
                          {% if block.settings.left_button_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                        >
                          <span>{{ block.settings.left_button_label }}</span>
                        </a>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {% endif %}

            {% if has_right %}
              <div class="universal-split__cell universal-split__cell--right universal-split__cell--{{ right_type }}">
                {% if right_type == 'image' %}
                  {% assign right_ratio = block.settings.right_image_ratio %}
                  {% assign right_alt = block.settings.right_image_alt | default: block.settings.right_image.alt | escape %}
                  {% if block.settings.right_image_link != blank %}
                    <a class="universal-split__media-link" href="{{ block.settings.right_image_link }}">
                  {% endif %}
                  <div class="universal-split__media universal-split__media--{{ right_ratio }}">
                    {% if block.settings.right_image != blank %}
                      {{
                        block.settings.right_image
                        | image_url: width: 2400
                        | image_tag:
                          loading: 'lazy',
                          widths: '375, 550, 750, 900, 1100, 1400, 1700, 2000, 2400',
                          class: 'universal-split__image',
                          alt: right_alt
                      }}
                    {% else %}
                      <div class="universal-split__placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
                    {% endif %}
                  </div>
                  {% if block.settings.right_image_link != blank %}
                    </a>
                  {% endif %}
                {% elsif right_type == 'content' %}
                  <div class="universal-split__content" style="max-width: {{ block.settings.right_content_max_width }}px;">
                    {% if block.settings.right_heading != blank %}
                      <h2 class="universal-split__heading universal-split__heading--right-{{ block.id }}">{{ block.settings.right_heading }}</h2>
                    {% endif %}

                    {% if block.settings.right_text != blank %}
                      <div class="universal-split__text universal-split__text--right-{{ block.id }} rte">{{ block.settings.right_text }}</div>
                    {% endif %}

                    {% if block.settings.right_show_button and block.settings.right_button_label != blank %}
                      <div class="universal-split__button-wrap universal-split__button-wrap--{{ block.settings.right_button_alignment }}">
                        <a
                          href="{% if block.settings.right_button_link != blank %}{{ block.settings.right_button_link }}{% else %}#{% endif %}"
                          class="universal-split__button"
                          {% if block.settings.right_button_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
                        >
                          <span>{{ block.settings.right_button_label }}</span>
                        </a>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #{{ section_id }} {
    background: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #{{ section_id }} .page-width--narrow {
    max-width: 1000px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  #{{ section_id }} .page-width--normal {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  #{{ section_id }} .page-width--wide {
    max-width: 1400px;
    margin: 0 auto;
    padding-left: 28px;
    padding-right: 28px;
  }

  #{{ section_id }} .universal-split__rows {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.rows_gap }}px;
  }

  #{{ section_id }} .universal-split__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: {{ section.settings.column_gap }}px;
    align-items: stretch;
  }

  #{{ section_id }} .universal-split__row--single-left .universal-split__grid,
  #{{ section_id }} .universal-split__row--single-right .universal-split__grid {
    grid-template-columns: minmax(0, 1fr);
  }

  #{{ section_id }} .universal-split__cell {
    min-width: 0;
  }

  #{{ section_id }} .universal-split__cell--content {
    display: flex;
    align-items: center;
  }

  #{{ section_id }} .universal-split__media-link {
    display: block;
    width: 100%;
  }

  #{{ section_id }} .universal-split__media {
    width: 100%;
    height: {{ section.settings.image_height_desktop }}px;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    background: transparent;
  }

  #{{ section_id }} .universal-split__media--adapt {
    height: auto;
    aspect-ratio: auto;
  }

  #{{ section_id }} .universal-split__media--square {
    height: auto;
    aspect-ratio: 1 / 1;
  }

  #{{ section_id }} .universal-split__media--portrait {
    height: auto;
    aspect-ratio: 4 / 5;
  }

  #{{ section_id }} .universal-split__media--landscape {
    height: auto;
    aspect-ratio: 4 / 3;
  }

  #{{ section_id }} .universal-split__media--wide {
    height: auto;
    aspect-ratio: 16 / 10;
  }

  #{{ section_id }} .universal-split__image,
  #{{ section_id }} .universal-split__placeholder svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  #{{ section_id }} .universal-split__image {
    object-fit: {{ section.settings.image_fit }};
    background: transparent;
  }

  #{{ section_id }} .universal-split__placeholder,
  #{{ section_id }} .universal-split__placeholder .placeholder-svg {
    width: 100%;
    height: 100%;
    background: #f1f1f1;
    fill: #c7c7c7;
  }

  #{{ section_id }} .universal-split__content {
    width: 100%;
    padding-top: {{ section.settings.content_padding_top }}px;
    padding-bottom: {{ section.settings.content_padding_bottom }}px;
  }

  #{{ section_id }} .universal-split__heading {
    margin: 0;
    word-break: break-word;
  }

  #{{ section_id }} .universal-split__text p,
  #{{ section_id }} .universal-split__text h1,
  #{{ section_id }} .universal-split__text h2,
  #{{ section_id }} .universal-split__text h3,
  #{{ section_id }} .universal-split__text h4,
  #{{ section_id }} .universal-split__text h5,
  #{{ section_id }} .universal-split__text h6,
  #{{ section_id }} .universal-split__text ul,
  #{{ section_id }} .universal-split__text ol {
    margin-top: 0;
  }

  #{{ section_id }} .universal-split__text p:last-child {
    margin-bottom: 0;
  }

  #{{ section_id }} .universal-split__button-wrap {
    margin-top: {{ section.settings.button_margin_top }}px;
    display: flex;
  }

  #{{ section_id }} .universal-split__button-wrap--left {
    justify-content: flex-start;
  }

  #{{ section_id }} .universal-split__button-wrap--center {
    justify-content: center;
  }

  #{{ section_id }} .universal-split__button-wrap--right {
    justify-content: flex-end;
  }

  #{{ section_id }} .universal-split__button {
    position: relative;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ section.settings.button_fixed_width }}px;
    max-width: 100%;
    min-height: 46px;
    padding: 14px 28px;
    background: {{ section.settings.button_bg }};
    color: {{ section.settings.button_text_color }};
    border: 1px solid {{ section.settings.button_border_color }};
    border-radius: {{ section.settings.button_radius }}px;
    text-decoration: none;
    font-size: {{ section.settings.button_text_size }}px;
    font-weight: {{ section.settings.button_text_weight }};
    letter-spacing: {{ section.settings.button_letter_spacing }}px;
    line-height: 1.2;
    box-shadow: 0 0 0 rgba(0, 0, 0, 0);
    transform: translateY(0);
    transition:
      background-color {{ section.settings.button_transition_duration }}ms ease,
      color {{ section.settings.button_transition_duration }}ms ease,
      border-color {{ section.settings.button_transition_duration }}ms ease,
      box-shadow {{ section.settings.button_transition_duration }}ms ease,
      transform {{ section.settings.button_transition_duration }}ms ease;
  }

  #{{ section_id }} .universal-split__button span {
    position: relative;
    z-index: 2;
  }

  #{{ section_id }} .universal-split__button::after {
    content: '';
    position: absolute;
    top: 0;
    right: -130%;
    width: 120%;
    height: 100%;
    background: linear-gradient(110deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.22) 50%, rgba(255, 255, 255, 0) 100%);
    transform: skewX(-18deg);
    transition: right {{ section.settings.button_shine_duration }}ms ease;
    pointer-events: none;
    z-index: 1;
  }

  #{{ section_id }} .universal-split__button:hover {
    background: {{ section.settings.button_bg_hover }};
    color: {{ section.settings.button_text_color_hover }};
    border-color: {{ section.settings.button_border_color_hover }};
    transform: translateY(-{{ section.settings.button_hover_lift }}px);
    box-shadow:
      0 {{ section.settings.button_shadow_y }}px {{ section.settings.button_shadow_blur }}px rgba(0, 0, 0, {{ section.settings.button_shadow_opacity | divided_by: 100.0 }}),
      0 2px 8px rgba(0, 0, 0, 0.08);
  }

  #{{ section_id }} .universal-split__button:hover::after {
    right: 120%;
  }

  #{{ section_id }} .universal-split__button:focus-visible {
    outline: 2px solid {{ section.settings.button_border_color_hover }};
    outline-offset: 2px;
  }

  @media (hover: none) {
    #{{ section_id }} .universal-split__button::after {
      display: none;
    }

    #{{ section_id }} .universal-split__button:hover {
      transform: none;
      box-shadow: none;
    }
  }

  {% for block in section.blocks %}
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__heading--left-{{ block.id }} {
      color: {{ block.settings.left_heading_color }};
      font-size: {{ block.settings.left_heading_size }}px;
      font-weight: {{ block.settings.left_heading_weight }};
      line-height: {{ block.settings.left_heading_line_height }};
      letter-spacing: {{ block.settings.left_heading_letter_spacing }}px;
      margin-bottom: {{ block.settings.left_heading_margin_bottom }}px;
    }

    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} {
      color: {{ block.settings.left_text_color }};
      font-size: {{ block.settings.left_text_size }}px;
      font-weight: {{ block.settings.left_text_weight }};
      line-height: {{ block.settings.left_text_line_height }};
      letter-spacing: {{ block.settings.left_text_letter_spacing }}px;
    }

    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} p,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} h1,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} h2,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} h3,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} h4,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} h5,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} h6,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} ul,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} ol {
      margin-bottom: {{ block.settings.left_paragraph_spacing }}px;
    }

    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__heading--right-{{ block.id }} {
      color: {{ block.settings.right_heading_color }};
      font-size: {{ block.settings.right_heading_size }}px;
      font-weight: {{ block.settings.right_heading_weight }};
      line-height: {{ block.settings.right_heading_line_height }};
      letter-spacing: {{ block.settings.right_heading_letter_spacing }}px;
      margin-bottom: {{ block.settings.right_heading_margin_bottom }}px;
    }

    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} {
      color: {{ block.settings.right_text_color }};
      font-size: {{ block.settings.right_text_size }}px;
      font-weight: {{ block.settings.right_text_weight }};
      line-height: {{ block.settings.right_text_line_height }};
      letter-spacing: {{ block.settings.right_text_letter_spacing }}px;
    }

    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} p,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} h1,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} h2,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} h3,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} h4,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} h5,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} h6,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} ul,
    #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} ol {
      margin-bottom: {{ block.settings.right_paragraph_spacing }}px;
    }
  {% endfor %}

  @media screen and (max-width: 989px) {
    #{{ section_id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #{{ section_id }} .page-width--narrow,
    #{{ section_id }} .page-width--normal,
    #{{ section_id }} .page-width--wide {
      padding-left: 16px;
      padding-right: 16px;
    }

    #{{ section_id }} .universal-split__rows {
      gap: {{ section.settings.rows_gap_mobile }}px;
    }

    #{{ section_id }} .universal-split__grid {
      gap: {{ section.settings.column_gap_mobile }}px;
    }

    #{{ section_id }} .universal-split__content {
      padding-top: {{ section.settings.content_padding_top_mobile }}px;
      padding-bottom: {{ section.settings.content_padding_bottom_mobile }}px;
    }

    #{{ section_id }} .universal-split__button {
      font-size: {{ section.settings.button_text_size_mobile }}px;
      width: min({{ section.settings.button_fixed_width }}px, 100%);
    }

    {% for block in section.blocks %}
      #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__heading--left-{{ block.id }} {
        font-size: {{ block.settings.left_heading_size_mobile }}px;
        margin-bottom: {{ block.settings.left_heading_margin_bottom_mobile }}px;
      }

      #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--left-{{ block.id }} {
        font-size: {{ block.settings.left_text_size_mobile }}px;
      }

      #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__heading--right-{{ block.id }} {
        font-size: {{ block.settings.right_heading_size_mobile }}px;
        margin-bottom: {{ block.settings.right_heading_margin_bottom_mobile }}px;
      }

      #{{ section_id }} #universal-split-row-{{ block.id }} .universal-split__text--right-{{ block.id }} {
        font-size: {{ block.settings.right_text_size_mobile }}px;
      }
    {% endfor %}
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .universal-split__row--two .universal-split__grid {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .universal-split__row--mobile-left-first .universal-split__cell--left {
      order: 1;
    }

    #{{ section_id }} .universal-split__row--mobile-left-first .universal-split__cell--right {
      order: 2;
    }

    #{{ section_id }} .universal-split__row--mobile-right-first .universal-split__cell--left {
      order: 2;
    }

    #{{ section_id }} .universal-split__row--mobile-right-first .universal-split__cell--right {
      order: 1;
    }

    #{{ section_id }} .universal-split__media {
      height: {{ section.settings.image_height_mobile }}px;
    }

    #{{ section_id }} .universal-split__media--adapt,
    #{{ section_id }} .universal-split__media--square,
    #{{ section_id }} .universal-split__media--portrait,
    #{{ section_id }} .universal-split__media--landscape,
    #{{ section_id }} .universal-split__media--wide {
      height: auto;
    }
  }
</style>

{% schema %}
{
  "name": "通用双列内容",
  "settings": [
    {
      "type": "header",
      "content": "分区设置"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "分区宽度",
      "default": "wide",
      "options": [
        { "value": "narrow", "label": "窄" },
        { "value": "normal", "label": "中" },
        { "value": "wide", "label": "宽" }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景颜色",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "桌面端上边距",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "桌面端下边距",
      "min": 0,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "移动端上边距",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "移动端下边距",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "全局布局设置"
    },
    {
      "type": "range",
      "id": "rows_gap",
      "label": "每组之间间距（桌面端）",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "rows_gap_mobile",
      "label": "每组之间间距（移动端）",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "左右列间距（桌面端）",
      "min": 12,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "column_gap_mobile",
      "label": "左右列间距（移动端）",
      "min": 8,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "content_padding_top",
      "label": "文案区上内边距（桌面端）",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "content_padding_bottom",
      "label": "文案区下内边距（桌面端）",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "content_padding_top_mobile",
      "label": "文案区上内边距（移动端）",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "content_padding_bottom_mobile",
      "label": "文案区下内边距（移动端）",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "全局图片设置"
    },
    {
